PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<dbName>?retryWrites=true&w=majority
CORS_ORIGIN=http://localhost:5173
JWT_ACCESS_SECRET=replace-with-strong-secret
JWT_REFRESH_SECRET=replace-with-strong-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
REDIS_URL=redis://default:<password>@<host>:<port>
REDIS_TLS=false
TRANSLATION_CACHE_TTL_SECONDS=86400
GOOGLE_TRANSLATE_API_KEY=<google-translate-api-key>
GOOGLE_APPLICATION_CREDENTIALS=C:/path/to/translation-api.json
GOOGLE_CLOUD_PROJECT=<your-gcp-project-id>
RUN_TRANSLATION_WORKER_IN_PROCESS=true
